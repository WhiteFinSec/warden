{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "warden-ai",
          "version": "1.6.0",
          "informationUri": "https://github.com/SharkRouter/warden",
          "rules": [
            {
              "id": "code_analyzer/D9",
              "shortDescription": {
                "text": "code_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Log the exception or handle it explicitly"
              }
            },
            {
              "id": "code_analyzer/D12",
              "shortDescription": {
                "text": "code_analyzer/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use model routing or configuration instead of hardcoded names"
              }
            },
            {
              "id": "code_analyzer/D2",
              "shortDescription": {
                "text": "code_analyzer/D2"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add input validation (pydantic, jsonschema, or manual checks)"
              }
            },
            {
              "id": "code_analyzer/D5",
              "shortDescription": {
                "text": "code_analyzer/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use logging.* or structlog.* for structured, searchable logs"
              }
            },
            {
              "id": "secrets_scanner/D4",
              "shortDescription": {
                "text": "secrets_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Move to secrets manager or .env file (excluded from VCS)"
              }
            },
            {
              "id": "audit_scanner/D5",
              "shortDescription": {
                "text": "audit_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Redact sensitive fields before logging"
              }
            },
            {
              "id": "dependency_scanner/D14",
              "shortDescription": {
                "text": "dependency_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pin version: openai==<specific_version>"
              }
            },
            {
              "id": "dependency_scanner/D4",
              "shortDescription": {
                "text": "dependency_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Verify this is the intended package, not a typosquat of 'transformers'"
              }
            },
            {
              "id": "framework_scanner/D6",
              "shortDescription": {
                "text": "framework_scanner/D6"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add CallbackManager with on_tool_start/on_chain_start handlers"
              }
            },
            {
              "id": "framework_scanner/D7",
              "shortDescription": {
                "text": "framework_scanner/D7"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add guardrail= parameter to agent/task config for output validation"
              }
            },
            {
              "id": "trap_defense_scanner/D17",
              "shortDescription": {
                "text": "trap_defense_scanner/D17"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Deploy trap defense layer on tool results"
              }
            }
          ]
        }
      },

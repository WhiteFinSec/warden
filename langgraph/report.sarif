{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "warden-ai",
          "version": "1.6.0",
          "informationUri": "https://github.com/SharkRouter/warden",
          "rules": [
            {
              "id": "code_analyzer/D5",
              "shortDescription": {
                "text": "code_analyzer/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use logging.* or structlog.* for structured, searchable logs"
              }
            },
            {
              "id": "code_analyzer/D9",
              "shortDescription": {
                "text": "code_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Log the exception or handle it explicitly"
              }
            },
            {
              "id": "code_analyzer/D15",
              "shortDescription": {
                "text": "code_analyzer/D15"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Verify tool result status/validity before using"
              }
            },
            {
              "id": "code_analyzer/D2",
              "shortDescription": {
                "text": "code_analyzer/D2"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add max_iterations, timeout, or explicit break condition"
              }
            },
            {
              "id": "audit_scanner/D5",
              "shortDescription": {
                "text": "audit_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add audit logging for all tool/agent executions"
              }
            },
            {
              "id": "dependency_scanner/D14",
              "shortDescription": {
                "text": "dependency_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pin version: langchain==<specific_version>"
              }
            },
            {
              "id": "framework_scanner/D6",
              "shortDescription": {
                "text": "framework_scanner/D6"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add CallbackManager with on_tool_start/on_chain_start handlers"
              }
            },
            {
              "id": "trap_defense_scanner/D17",
              "shortDescription": {
                "text": "trap_defense_scanner/D17"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Deploy trap defense layer on tool results"
              }
            }
          ]
        }
      },

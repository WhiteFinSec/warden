{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "warden-ai",
          "version": "1.6.0",
          "informationUri": "https://github.com/SharkRouter/warden",
          "rules": [
            {
              "id": "code_analyzer/D9",
              "shortDescription": {
                "text": "code_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Log the exception or handle it explicitly"
              }
            },
            {
              "id": "code_analyzer/D15",
              "shortDescription": {
                "text": "code_analyzer/D15"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Verify tool result status/validity before using"
              }
            },
            {
              "id": "code_analyzer/D12",
              "shortDescription": {
                "text": "code_analyzer/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use model routing or configuration instead of hardcoded names"
              }
            },
            {
              "id": "code_analyzer/D5",
              "shortDescription": {
                "text": "code_analyzer/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use logging.* or structlog.* for structured, searchable logs"
              }
            },
            {
              "id": "code_analyzer/D3",
              "shortDescription": {
                "text": "code_analyzer/D3"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Scope tools to only what the agent needs"
              }
            },
            {
              "id": "code_analyzer/D2",
              "shortDescription": {
                "text": "code_analyzer/D2"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add max_iterations, timeout, or explicit break condition"
              }
            },
            {
              "id": "secrets_scanner/D4",
              "shortDescription": {
                "text": "secrets_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Move to secrets manager or .env file (excluded from VCS)"
              }
            },
            {
              "id": "audit_scanner/D5",
              "shortDescription": {
                "text": "audit_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Redact sensitive fields before logging"
              }
            },
            {
              "id": "agent_arch_scanner/D8",
              "shortDescription": {
                "text": "agent_arch_scanner/D8"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Add state machine (ACTIVE/SUSPENDED/RETIRED) for agent lifecycle"
              }
            },
            {
              "id": "agent_arch_scanner/D12",
              "shortDescription": {
                "text": "agent_arch_scanner/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Track token usage and costs per agent execution"
              }
            },
            {
              "id": "agent_arch_scanner/D3",
              "shortDescription": {
                "text": "agent_arch_scanner/D3"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Scope tools to only what the agent needs for its task"
              }
            },
            {
              "id": "dependency_scanner/D14",
              "shortDescription": {
                "text": "dependency_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pin version: crewai==<specific_version>"
              }
            },
            {
              "id": "cicd_scanner/D3",
              "shortDescription": {
                "text": "cicd_scanner/D3"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Add concurrency: group with cancel-in-progress to prevent parallel deploys"
              }
            },
            {
              "id": "cicd_scanner/D14",
              "shortDescription": {
                "text": "cicd_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "help": {
                "text": "Add environment: production with required reviewers in GitHub settings"
              }
            },
            {
              "id": "cicd_scanner/D4",
              "shortDescription": {
                "text": "cicd_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Use OIDC (id-token: write) for cloud auth instead of static secrets"
              }
            },
            {
              "id": "framework_scanner/D7",
              "shortDescription": {
                "text": "framework_scanner/D7"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add guardrail= parameter to agent/task config for output validation"
              }
            },
            {
              "id": "framework_scanner/D6",
              "shortDescription": {
                "text": "framework_scanner/D6"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Set max_iter= and/or timeout= to prevent runaway agent loops"
              }
            },
            {
              "id": "cloud_scanner/D1",
              "shortDescription": {
                "text": "cloud_scanner/D1"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Move AI service endpoints to environment variables or configuration files"
              }
            },
            {
              "id": "cloud_scanner/D10",
              "shortDescription": {
                "text": "cloud_scanner/D10"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add Azure ContentSafetyClient to analyse prompts/responses for harmful content"
              }
            },
            {
              "id": "cloud_scanner/D4",
              "shortDescription": {
                "text": "cloud_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pass service_account or credentials parameter for explicit IAM scoping"
              }
            },
            {
              "id": "trap_defense_scanner/D17",
              "shortDescription": {
                "text": "trap_defense_scanner/D17"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Deploy trap defense layer on tool results"
              }
            }
          ]
        }
      },
      "results": [

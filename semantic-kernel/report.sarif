{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "warden-ai",
          "version": "1.6.0",
          "informationUri": "https://github.com/SharkRouter/warden",
          "rules": [
            {
              "id": "code_analyzer/D5",
              "shortDescription": {
                "text": "code_analyzer/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use logging.* or structlog.* for structured, searchable logs"
              }
            },
            {
              "id": "code_analyzer/D12",
              "shortDescription": {
                "text": "code_analyzer/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use model routing or configuration instead of hardcoded names"
              }
            },
            {
              "id": "code_analyzer/D15",
              "shortDescription": {
                "text": "code_analyzer/D15"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Verify tool result status/validity before using"
              }
            },
            {
              "id": "code_analyzer/D9",
              "shortDescription": {
                "text": "code_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Log the exception or handle it explicitly"
              }
            },
            {
              "id": "code_analyzer/D2",
              "shortDescription": {
                "text": "code_analyzer/D2"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add input validation (pydantic, jsonschema, or manual checks)"
              }
            },
            {
              "id": "secrets_scanner/D4",
              "shortDescription": {
                "text": "secrets_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Move to secrets manager or .env file (excluded from VCS)"
              }
            },
            {
              "id": "audit_scanner/D5",
              "shortDescription": {
                "text": "audit_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Redact sensitive fields before logging"
              }
            },
            {
              "id": "agent_arch_scanner/D12",
              "shortDescription": {
                "text": "agent_arch_scanner/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Track token usage and costs per agent execution"
              }
            },
            {
              "id": "agent_arch_scanner/D8",
              "shortDescription": {
                "text": "agent_arch_scanner/D8"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add role/permission checks before tool dispatch"
              }
            },
            {
              "id": "agent_arch_scanner/D3",
              "shortDescription": {
                "text": "agent_arch_scanner/D3"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Scope tools to only what the agent needs for its task"
              }
            },
            {
              "id": "dependency_scanner/D14",
              "shortDescription": {
                "text": "dependency_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pin version: anthropic==<specific_version>"
              }
            },
            {
              "id": "framework_scanner/D6",
              "shortDescription": {
                "text": "framework_scanner/D6"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Set code_execution_config={'use_docker': True} for safe code execution"
              }
            },
            {
              "id": "framework_scanner/D7",
              "shortDescription": {
                "text": "framework_scanner/D7"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Define is_termination_msg function to control when agents stop"
              }
            },
            {
              "id": "cloud_scanner/D10",
              "shortDescription": {
                "text": "cloud_scanner/D10"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add Azure ContentSafetyClient to analyse prompts/responses for harmful content"
              }
            },
            {
              "id": "cloud_scanner/D1",
              "shortDescription": {
                "text": "cloud_scanner/D1"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Move AI service endpoints to environment variables or configuration files"
              }
            },
            {
              "id": "cloud_scanner/D4",
              "shortDescription": {
                "text": "cloud_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pass service_account or credentials parameter for explicit IAM scoping"
              }
            },
            {
              "id": "cloud_scanner/D11",
              "shortDescription": {
                "text": "cloud_scanner/D11"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add guardrailIdentifier and guardrailVersion parameters to invoke_model calls"
              }
            },
            {
              "id": "trap_defense_scanner/D17",
              "shortDescription": {
                "text": "trap_defense_scanner/D17"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Deploy trap defense layer on tool results"
              }
            }
          ]
        }
      },
      "results": [

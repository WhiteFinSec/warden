{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "warden-ai",
          "version": "1.5.1",
          "informationUri": "https://github.com/SharkRouter/warden",
          "rules": [
            {
              "id": "code_analyzer/D5",
              "shortDescription": {
                "text": "code_analyzer/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use logging.* or structlog.* for structured, searchable logs"
              }
            },
            {
              "id": "code_analyzer/D9",
              "shortDescription": {
                "text": "code_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Log the exception or handle it explicitly"
              }
            },
            {
              "id": "code_analyzer/D12",
              "shortDescription": {
                "text": "code_analyzer/D12"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use model routing or configuration instead of hardcoded names"
              }
            },
            {
              "id": "code_analyzer/D1",
              "shortDescription": {
                "text": "code_analyzer/D1"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Set baseURL to your governance gateway"
              }
            },
            {
              "id": "mcp_scanner/D1",
              "shortDescription": {
                "text": "mcp_scanner/D1"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Static analysis can only evaluate inline tool definitions. Consider adding tool definitions to the config for full governance scoring."
              }
            },
            {
              "id": "infra_analyzer/D4",
              "shortDescription": {
                "text": "infra_analyzer/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add USER directive to run as non-root user"
              }
            },
            {
              "id": "infra_analyzer/D9",
              "shortDescription": {
                "text": "infra_analyzer/D9"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Add resources.limits and resources.requests"
              }
            },
            {
              "id": "secrets_scanner/D4",
              "shortDescription": {
                "text": "secrets_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Move to secrets manager or .env file (excluded from VCS)"
              }
            },
            {
              "id": "agent_arch_scanner/D3",
              "shortDescription": {
                "text": "agent_arch_scanner/D3"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Scope tools to only what the agent needs for its task"
              }
            },
            {
              "id": "dependency_scanner/D5",
              "shortDescription": {
                "text": "dependency_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Consider local PII detection to keep data on-premise"
              }
            },
            {
              "id": "dependency_scanner/D14",
              "shortDescription": {
                "text": "dependency_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Pin version: openai==<specific_version>"
              }
            },
            {
              "id": "audit_scanner/D5",
              "shortDescription": {
                "text": "audit_scanner/D5"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Redact sensitive fields before logging"
              }
            },
            {
              "id": "cicd_scanner/D4",
              "shortDescription": {
                "text": "cicd_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Use OIDC (id-token: write) for cloud auth instead of static secrets"
              }
            },
            {
              "id": "cicd_scanner/D3",
              "shortDescription": {
                "text": "cicd_scanner/D3"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Remove continue-on-error or scope it to non-critical steps only"
              }
            },
            {
              "id": "cicd_scanner/D14",
              "shortDescription": {
                "text": "cicd_scanner/D14"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "help": {
                "text": "Add environment: production with required reviewers in GitHub settings"
              }
            },
            {
              "id": "iac_scanner/D4",
              "shortDescription": {
                "text": "iac_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Add BucketEncryption property with SSEAlgorithm: aws:kms or AES256"
              }
            },
            {
              "id": "iac_scanner/D13",
              "shortDescription": {
                "text": "iac_scanner/D13"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Add DeletionPolicy: Retain or Snapshot to prevent accidental data loss"
              }
            },
            {
              "id": "cloud_scanner/D1",
              "shortDescription": {
                "text": "cloud_scanner/D1"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Move AI service endpoints to environment variables or configuration files"
              }
            },
            {
              "id": "cloud_scanner/D4",
              "shortDescription": {
                "text": "cloud_scanner/D4"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Remove API keys from source; use secrets manager, env vars, or managed identity"
              }
            }
          ]
        }
      },
      "results": [
